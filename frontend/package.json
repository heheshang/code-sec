{
  "name": "code-sec-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Code-sec audit workbench frontend — human-in-the-loop security audit platform",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
