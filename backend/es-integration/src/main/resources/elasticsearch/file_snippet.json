{
  "settings": {
    "index": {
      "number_of_shards": 1,
      "number_of_replicas": 0,
      "refresh_interval": "10s",
      "max_result_window": 10000
    }
  },
  "mappings": {
    "dynamic": "strict",
    "properties": {
      "file_path": {
        "type": "keyword",
        "fields": {
          "text": {
            "type": "text",
            "analyzer": "standard"
          }
        }
      },
      "project_id": {
        "type": "keyword"
      },
      "language": {
        "type": "keyword"
      },
      "indexed_at": {
        "type": "date",
        "format": "yyyy-MM-dd'T'HH:mm:ss||yyyy-MM-dd||epoch_millis"
      }
    }
  }
}
