{
  "settings": {
    "index": {
      "number_of_shards": 1,
      "number_of_replicas": 0,
      "refresh_interval": "5s",
      "max_result_window": 10000,
      "analysis": {
        "analyzer": {
          "ik_smart_analyzer": {
            "type": "custom",
            "tokenizer": "ik_smart",
            "filter": ["lowercase"]
          },
          "standard_analyzer": {
            "type": "custom",
            "tokenizer": "standard",
            "filter": ["lowercase", "stop"]
          }
        }
      }
    }
  },
  "mappings": {
    "dynamic": "strict",
    "properties": {
      "id": {
        "type": "keyword"
      },
      "project_id": {
        "type": "keyword"
      },
      "rule_id": {
        "type": "keyword"
      },
      "severity": {
        "type": "keyword"
      },
      "exploitability": {
        "type": "keyword"
      },
      "title": {
        "type": "text",
        "analyzer": "ik_smart_analyzer",
        "search_analyzer": "ik_smart_analyzer",
        "fields": {
          "standard": {
            "type": "text",
            "analyzer": "standard_analyzer",
            "search_analyzer": "standard_analyzer"
          },
          "keyword": {
            "type": "keyword",
            "ignore_above": 256
          }
        },
        "boost": 3.0
      },
      "description": {
        "type": "text",
        "analyzer": "ik_smart_analyzer",
        "search_analyzer": "ik_smart_analyzer",
        "fields": {
          "standard": {
            "type": "text",
            "analyzer": "standard_analyzer",
            "search_analyzer": "standard_analyzer"
          }
        },
        "boost": 2.0
      },
      "code_snippet": {
        "type": "text",
        "analyzer": "standard_analyzer",
        "search_analyzer": "standard_analyzer",
        "fields": {
          "keyword": {
            "type": "keyword",
            "ignore_above": 512
          }
        }
      },
      "file_path": {
        "type": "keyword",
        "fields": {
          "text": {
            "type": "text",
            "analyzer": "standard_analyzer"
          }
        }
      },
      "cwe": {
        "type": "keyword"
      },
      "engine": {
        "type": "keyword"
      },
      "discovered_at": {
        "type": "date",
        "format": "yyyy-MM-dd'T'HH:mm:ss||yyyy-MM-dd||epoch_millis"
      },
      "discovered_by": {
        "type": "keyword"
      }
    }
  }
}
